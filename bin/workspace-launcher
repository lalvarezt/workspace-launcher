#!/usr/bin/env bash

set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)
repo_root=$(cd -- "$script_dir/.." && pwd -P)
bin_path=${WORKSPACE_LAUNCHER_DEV_BIN:-$repo_root/.build/workspace-launcher}

if [[ ! -x $bin_path ]]; then
	printf '%s\n' "workspace-launcher: compiled binary not found at $bin_path" >&2
	printf '%s\n' "workspace-launcher: run 'make build' or set WORKSPACE_LAUNCHER_DEV_BIN" >&2
	exit 1
fi

exec "$bin_path" "$@"
